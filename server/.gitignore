# ====================
# Server .gitignore  (Node.js / Express)
# ====================

# ── Dependencies ──────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment / Secrets ─────────────────────────────────
.env
.env.*
!.env.example        # keep the template committed

# ── Build / compiled output ───────────────────────────────
dist/
build/

# ── Logs ──────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Uploaded / generated files ────────────────────────────
uploads/
tmp/
temp/
*.pdf.tmp

# ── OS generated ──────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editors / IDEs ────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Misc ──────────────────────────────────────────────────
*.local
coverage/
.nyc_output/