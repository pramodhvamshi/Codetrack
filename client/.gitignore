# ====================
# Client .gitignore  (React + Vite)
# ====================

# ── Dependencies ──────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build outputs ─────────────────────────────────────────
dist/
dist-ssr/
build/

# ── Vite cache ────────────────────────────────────────────
.vite/
.vite-cache/

# ── Environment / Secrets ─────────────────────────────────
.env
.env.*
!.env.example        # keep the example template committed
*.local

# ── Logs ──────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── OS generated ──────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editors / IDEs ────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Testing / coverage ────────────────────────────────────
coverage/
.nyc_output/

# ── TypeScript ────────────────────────────────────────────
*.tsbuildinfo
